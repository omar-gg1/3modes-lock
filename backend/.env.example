# Smart Lock backend secrets — COPY this to .env and fill in real values.
# .env is gitignored; never commit real secrets.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=smartlock
MYSQL_USER=smartlock
MYSQL_PASSWORD=change-me-user

# --- MQTT broker auth ---
# These MUST match: (1) the mosquitto passwd file, and (2) the firmware's
# MQTT_USERNAME / MQTT_PASSWORD in wifi_config.h.
MQTT_USERNAME=lockuser
MQTT_PASSWORD=change-me-mqtt

# --- Mode 3 cloud verifier (ArcFace) ---
# Shared secret the ESP32 (and the app) must send as X-API-Key to /verify and
# /enroll. Make it long + random.
VERIFIER_API_KEY=change-me-long-random-key
# buffalo_l = best accuracy (~1GB RAM). Switch to buffalo_s if the EC2 is tight.
INSIGHTFACE_MODEL=buffalo_l
# Cosine-similarity match threshold; tune from FAR/FRR (Phase B).
MATCH_THRESHOLD=0.40

# --- Production only (docker-compose.prod.yml on EC2) ---
# Where the CI pushes the images. Lowercase owner/repo.
IMAGE_PREFIX=ghcr.io/omar-gg1/3modes-lock

# --- Nixis control plane (Plan A) ---
# 32-byte HMAC secret, hex (64 chars). MUST equal the firmware's
# CMD_HMAC_SECRET in wifi_config.h. Gates command authenticity independent of
# the broker password. Generate: python -c "import secrets;print(secrets.token_hex(32))"
CMD_HMAC_SECRET=change-me-64-hex-chars
# JWT signing secret for app login tokens.
JWT_SECRET=change-me
# App login credentials (single admin user for Phase 1).
NIXIS_USER=admin
NIXIS_PASSWORD=change-me
